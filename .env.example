# ===== Rik's Context Engine - Environment Variables ===== #
# Copy this file to .env and fill in your values

# ===== Application ===== #
PYTHONUNBUFFERED=1
DATA_DIR=/app/data

# ===== ChromaDB ===== #
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ===== Ollama (Local LLM) ===== #
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4-31b-q4

# ===== OpenAI (Optional) ===== #
# OPENAI_API_KEY=sk-...

# ===== Anthropic (Optional) ===== #
# ANTHROPIC_API_KEY=sk-ant-...

# ===== Logging ===== #
LOG_LEVEL=INFO